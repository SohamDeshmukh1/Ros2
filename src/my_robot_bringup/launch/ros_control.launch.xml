<launch>
    <let name="urdf_path" value="$(find-pkg-share my_robot_description)/urdf/my_robot.urdf.xacro"/>
    <let name="rviz_path" value="$(find-pkg-share my_robot_description)/rviz/test1.rviz" />

    <node name="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description" value="$(command 'xacro $(var urdf_path)')" />
    </node>

    <node pkg="controller_manager" exec="ros2_control_node" name="controller_manager" output="screen">
        <param from="$(find-pkg-share my_robot_bringup)/config/my_robot_controller.yaml"/>
    </node>

    <node pkg="controller_manager" exec="spawner" args="joint_state_broadcaster" output="screen" />
    <node pkg="controller_manager" exec="spawner" args="diff_drive_controller" output="screen" />

    <node pkg="rviz2" exec="rviz2" output="screen" args="-d $(var rviz_path)"></node>

    <!-- This was Totally made by me lets see if it works HEHEHHE -->
</launch> 
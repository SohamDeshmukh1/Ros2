<?xml version="1.0"?>
<robot xmlns:xacro="https://www.ros.org/wiki/xacro">
        <link name="base_arm_link">
            <visual>
                <origin xyz="0 0 ${box_height/2}" rpy="0 0 0"/>
                <geometry>
                    <box size="${box_length} ${box_width} ${box_height}" />
                </geometry>
                <material name="orange"/>
            </visual>
            <collision>
                <origin xyz="0 0 ${box_height/2}" rpy="0 0 0"/>
                <geometry>
                    <box size="${box_length} ${box_width} ${box_height}" />
                </geometry>
            </collision>
            <xacro:arm_base_interia o_rpy="0 0 ${box_height/2}" o_xyz="0 0 0" />
        </link>
        <link name="forearm_link">
            <visual>
                <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0" />
                <geometry>
                    <cylinder radius="${arm_width}" length="${arm_length}" />
                </geometry>
                <material name="orange"/>
            </visual>
            <collision>
                <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0" />
                <geometry>
                    <cylinder radius="${arm_width}" length="${arm_length}" />
                </geometry>
            </collision>
            <xacro:arm_interia o_rpy="0 0 0" o_xyz="0 0 ${arm_length/2}" />
        </link>

        <link name="hand_link">
            <visual>
                <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0" />
                <geometry>
                    <cylinder radius="${arm_width}" length="${arm_length}" />
                </geometry>
                <material name="yellow"/>
            </visual>
            <collision>
                <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0" />
                <geometry>
                    <cylinder radius="${arm_width}" length="${arm_length}" />
                </geometry>
            </collision>
            <xacro:arm_interia o_rpy="0 0 0" o_xyz="0 0 ${arm_length/2}" />
        </link>

        <joint name="arm_base_link" type="revolute">
            <parent link="base_arm_link" />
            <child link="forearm_link" />
            <origin xyz="0 0 ${box_height}" rpy="0 0 0" />
            <axis xyz="1 0 0" />
            <limit lower="0" upper="${pi/2}" effort="100" velocity="100" />
            <dynamics friction="0.3" damping="0.3" />
        </joint>

        <joint name="forearm_arm_joint" type="revolute">
            <parent link="forearm_link" />
            <child link="hand_link" />
            <origin xyz="0 0 ${arm_length}" rpy="0 0 0" />
            <axis xyz="1 0 0" />
            <limit lower="0" upper="${pi/2}" effort="100" velocity="100" />
            <dynamics friction="0.3" damping="0.3" />
        </joint>
    </robot>